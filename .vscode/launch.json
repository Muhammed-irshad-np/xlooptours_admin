    "version": "0.2.0",
    "configurations": [
        {
            "name": "xloop_invoice (Staging / Dev)",
            "request": "launch",
            "type": "dart",
            "args": [
                "--web-port",
                "5005",
                "--dart-define=ENV=dev"
            ]
        },
        {
            "name": "xloop_invoice (Production)",
            "request": "launch",
            "type": "dart",
            "args": [
                "--web-port",
                "5005"
            ]
        },
        {
            "name": "xloop_invoice (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "xloop_invoice (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}